  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Shopping Assistant (Claude + macOS)",
      "request": "launch",
      "type": "dart",
      "deviceId": "macos",
      "args": [
        "--dart-define=ANTHROPIC_API_KEY=${env:CLAUDE_SHOPPING_ASSISTANT_KEY}"
      ]
    },
    {
      "name": "Launch Shopping Assistant (Gemini + Chrome)",
      "request": "launch",
      "type": "dart",
      "deviceId": "chrome",
    }
  ]
}